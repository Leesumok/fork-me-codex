# GitHub repository to attach this self-hosted runner to.
# Example: octocat/hello-world
GITHUB_REPOSITORY=OWNER/REPO

# Short-lived token from:
# Repository Settings > Actions > Runners > New self-hosted runner
RUNNER_TOKEN=PASTE_RUNNER_REGISTRATION_TOKEN_HERE

# Any stable name for the local runner.
RUNNER_NAME=codex-local

# The workflows require the `codex` label. `self-hosted` is added by GitHub automatically.
RUNNER_LABELS=codex

# Optional. Leave as latest unless you need to pin a runner version.
RUNNER_VERSION=latest
