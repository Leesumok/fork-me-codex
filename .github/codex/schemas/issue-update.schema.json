{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex issue update",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "title",
    "body",
    "summary_comment",
    "needs_clarification"
  ],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "body": {
      "type": "string",
      "minLength": 1
    },
    "summary_comment": {
      "type": "string",
      "minLength": 1
    },
    "needs_clarification": {
      "type": "boolean"
    }
  }
}
